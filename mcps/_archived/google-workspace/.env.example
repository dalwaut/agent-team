# Google Workspace Agent — Environment Variables
# These are loaded by the MCP server at runtime.

# Shared Drive folder where agent is allowed to write
# Get this from the Google Drive URL: /folders/XXXXXXXXX
GOOGLE_AGENT_WORKSPACE_FOLDER_ID=1i2usqWNFXQ03OyWOkqt2gNfuUpiu-lPA

# Safety switch — restrict writes to Agent Workspace only (default: true)
GOOGLE_WORKSPACE_WRITE_RESTRICTED=true
