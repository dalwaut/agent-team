{
  "version": "1.0.0",
  "workers": {
    "eliza-runtime": {
      "name": "Eliza Runtime",
      "type": "long-running",
      "runtime": "bun",
      "entry": "tools/opai-eliza/src/index.ts",
      "managed": true,
      "disabled": false,
      "port": 8085,
      "trigger": {
        "mode": "always-on"
      },
      "permissions": {
        "read_paths": ["tools/opai-eliza/characters/"],
        "write_paths": [],
        "network": true
      },
      "guardrails": {
        "read_only": false,
        "max_turns": null,
        "timeout_seconds": null,
        "git_push": false
      },
      "intent": "Manages ElizaOS autonomous agent runtime instances",
      "success_criteria": {
        "health_endpoint": "http://127.0.0.1:8085/health"
      }
    },
    "email-manager": {
      "name": "Email Manager",
      "type": "long-running",
      "runtime": "node",
      "entry": "tools/opai-email-agent/index.js",
      "managed": true,
      "disabled": false,
      "port": null,
      "trigger": {
        "mode": "internal-polling",
        "interval_minutes": 30
      },
      "vault_keys": [
        "opai-email-agent"
      ],
      "permissions": {
        "file_access": [
          "tools/opai-email-agent/data/"
        ],
        "supabase_tables": [
          "audit_log"
        ],
        "can_send": false
      },
      "guardrails": {
        "requires_approval": [
          "send_email",
          "delete_email"
        ],
        "max_actions_per_hour": 20,
        "prompt_protection": true
      },
      "health_check": null,
      "restart_on_failure": true,
      "max_restarts": 3,
      "restart_delay_sec": 30,
      "note": "Re-enabled 2026-03-06 after loop fix (4 defense layers in arl-engine.js).",
      "intent": {
        "purpose": "Manage email operations",
        "goals": [
          "triage incoming email",
          "draft accurate responses",
          "send on schedule"
        ],
        "capabilities": [
          "email-triage",
          "email-drafting",
          "email-sending",
          "transcript-processing"
        ],
        "anti_goals": [
          "sending without approval",
          "deleting emails without confirmation"
        ]
      }
    },
    "discord-bot": {
      "name": "Discord Bridge",
      "type": "long-running",
      "runtime": "node",
      "entry": "tools/discord-bridge/start-bot.sh",
      "systemd_unit": "opai-discord-bot",
      "port": null,
      "trigger": {
        "mode": "event-driven",
        "source": "discord-gateway"
      },
      "vault_keys": [
        "discord-bridge"
      ],
      "permissions": {
        "file_access": [
          "tools/discord-bridge/data/"
        ],
        "supabase_tables": [
          "audit_log",
          "conversations"
        ],
        "can_send": true
      },
      "guardrails": {
        "requires_approval": [],
        "max_actions_per_hour": 500,
        "prompt_protection": true
      },
      "health_check": null,
      "restart_on_failure": true,
      "max_restarts": 10,
      "restart_delay_sec": 10,
      "intent": {
        "purpose": "Discord community bridge",
        "goals": [
          "relay messages accurately",
          "maintain community presence",
          "bridge Discord to OPAI"
        ],
        "capabilities": [
          "discord-messaging",
          "community-management"
        ],
        "anti_goals": [
          "spamming channels",
          "responding without context"
        ]
      }
    },
    "wordpress-manager": {
      "name": "WordPress Manager",
      "type": "hybrid",
      "runtime": "python",
      "entry": "tools/opai-wordpress/app.py",
      "systemd_unit": "opai-wordpress",
      "port": 8096,
      "trigger": {
        "mode": "cron+manual",
        "schedule": "0 */6 * * *"
      },
      "vault_keys": [
        "opai-wordpress"
      ],
      "permissions": {
        "file_access": [
          "tools/opai-wordpress/"
        ],
        "supabase_tables": [
          "audit_log"
        ],
        "external_apis": [
          "wordpress",
          "woocommerce",
          "managewp"
        ]
      },
      "guardrails": {
        "requires_approval": [
          "deploy_production",
          "update_plugins"
        ],
        "max_actions_per_hour": 50,
        "prompt_protection": true
      },
      "health_check": "http://127.0.0.1:8096/health",
      "restart_on_failure": true,
      "max_restarts": 5,
      "restart_delay_sec": 30,
      "note": "Dual-role: independent app (portal tile) + registered worker for Engine scheduling",
      "intent": {
        "purpose": "WordPress site management",
        "goals": [
          "keep sites healthy",
          "publish content on schedule",
          "manage plugins safely"
        ],
        "capabilities": [
          "wordpress-admin",
          "content-publishing",
          "plugin-management"
        ],
        "anti_goals": [
          "deploying to production without approval",
          "updating plugins without testing"
        ]
      }
    },
    "project-reviewer": {
      "name": "Project Reviewer",
      "type": "task",
      "runtime": "claude-cli",
      "prompt_file": "scripts/prompt_reviewer.txt",
      "trigger": {
        "mode": "manual",
        "also": "squad:audit"
      },
      "permissions": {
        "file_access": [
          "read-only"
        ],
        "can_send": false
      },
      "guardrails": {
        "read_only": true,
        "max_turns": 25,
        "timeout_minutes": 15,
        "model": "sonnet"
      },
      "output": "reports/{date}/{worker-name}.md",
      "intent": {
        "purpose": "Review code for quality and correctness",
        "goals": [
          "catch bugs before merge",
          "enforce coding standards",
          "identify security issues"
        ],
        "capabilities": [
          "code-review",
          "security-review",
          "quality-audit"
        ],
        "anti_goals": [
          "rewriting code",
          "implementing fixes"
        ]
      },
      "success_criteria": {
        "min_output_length": 200,
        "must_contain": [
          "Findings",
          "Recommendations"
        ],
        "must_not_contain": [
          "FATAL ERROR"
        ],
        "exit_code_zero": true
      }
    },
    "project-builder": {
      "name": "Project Builder",
      "type": "task",
      "runtime": "claude-cli",
      "prompt_file": "scripts/prompt_builder.txt",
      "trigger": {
        "mode": "manual"
      },
      "permissions": {
        "file_access": [
          "task-context-path"
        ],
        "can_send": false
      },
      "guardrails": {
        "read_only": false,
        "max_turns": 40,
        "timeout_minutes": 20,
        "model": "sonnet",
        "requires_approval": [
          "write_file",
          "delete_file"
        ]
      },
      "output": "reports/{date}/{worker-name}.md",
      "intent": {
        "purpose": "Implement code changes from task specifications",
        "goals": [
          "ship working code",
          "follow project conventions",
          "minimize scope creep"
        ],
        "capabilities": [
          "code-build",
          "feature-implementation",
          "bug-fix",
          "refactor",
          "spec-generation"
        ],
        "anti_goals": [
          "refactoring unrelated code",
          "adding unasked features"
        ]
      },
      "success_criteria": {
        "min_output_length": 150,
        "must_contain": [
          "Build Complete",
          "Files"
        ],
        "must_not_contain": [
          "FATAL ERROR"
        ],
        "exit_code_zero": true
      }
    },
