# ============================================
# OPAI Workspace .gitignore
# ============================================
# Only track: tools/, config/, scripts/, Library/, Templates/, tasks/, workflows/
# Everything personal, generated, or runtime stays out.

# ══════════════════════════════════════════════
# Personal / Workspace Content
# ══════════════════════════════════════════════
Projects/
Research/
Clients/
Documents/
notes/
logs/
memory/
gemini-scribe/
Cursor/
.obsidian/

# ══════════════════════════════════════════════
# Secrets & Credentials
# ══════════════════════════════════════════════
.env
.env.*
!.env.example
Credentials.md
tools/opai-vault/migrate_credentials.py

# ══════════════════════════════════════════════
# Runtime Data & State
# ══════════════════════════════════════════════
**/data/
**/venv/
*.db
*.sqlite

# ══════════════════════════════════════════════
# Generated Output
# ══════════════════════════════════════════════
reports/
!reports/.gitkeep

# ══════════════════════════════════════════════
# Dependencies (install fresh)
# ══════════════════════════════════════════════
node_modules/
package-lock.json

# ══════════════════════════════════════════════
# Temp & OS Files
# ══════════════════════════════════════════════
claude_prompt_*.txt
temp_workflows.json
nul
*.png
Notes.md
.DS_Store
Thumbs.db
desktop.ini

# ══════════════════════════════════════════════
# IDE / Editor / Tools
# ══════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
.playwright-mcp/

# ══════════════════════════════════════════════
# Python
# ══════════════════════════════════════════════
__pycache__/
*.pyc
.venv/

# ══════════════════════════════════════════════
# n8n Workflows (large JSON files, sync separately)
# ══════════════════════════════════════════════
Library/n8n/Workflows/

# ══════════════════════════════════════════════
# Library — Reference files (personal, not system docs)
# ══════════════════════════════════════════════
Library/References/

# ══════════════════════════════════════════════
# Project Structure Templates (cloud-synced scaffolds)
# ══════════════════════════════════════════════
Templates/templates-projects/*/Codebase/
Templates/templates-projects/*/Ag-Build-Tasks/
Templates/templates-projects/*/Agent-Tasks/
Templates/templates-projects/*/Debug-log/
Templates/templates-projects/*/Dev-Plan/
Templates/templates-projects/*/Notes/
Templates/templates-projects/*/Research/
Templates/templates-projects/*/Review-log/

# ══════════════════════════════════════════════
# MCP servers (have their own repos or are installed)
# ══════════════════════════════════════════════
mcps/stitch-skills/

# ══════════════════════════════════════════════
# Migration Backups
# ══════════════════════════════════════════════
_backup_*/

# ══════════════════════════════════════════════
# Synology Drive Working Directory
# ══════════════════════════════════════════════
.SynologyWorkingDirectory/

# ══════════════════════════════════════════════
# Claude Code
# ══════════════════════════════════════════════
.claude/

# ══════════════════════════════════════════════
# Standalone Projects (have their own repos)
# ══════════════════════════════════════════════
tools/opai-agent/
tools/scc-ide/
tools/opai-dev/
