# OPAI Telegram Bot Configuration
# Copy to .env and fill in values

# Bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Webhook secret (generate: openssl rand -hex 32)
WEBHOOK_SECRET=

# Webhook URL (set automatically by set-webhook.js)
WEBHOOK_URL=https://opai.boutabyte.com/telegram/webhook

# Server port
PORT=8110

# OPAI workspace root
OPAI_ROOT=/workspace/synced/opai

# Claude CLI timeout (ms)
CLAUDE_TIMEOUT=300000

# Owner Telegram user ID (gets full admin access)
OWNER_USER_ID=

# Admin group chat ID (optional — for forum topic management)
ADMIN_GROUP_ID=

# Groq API key (for voice message transcription via Whisper)
GROQ_API_KEY=
