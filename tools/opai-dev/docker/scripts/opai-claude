#!/bin/bash
# opai-claude — Claude Code CLI wrapper for Theia containers
#
# Connects to the Claude Code bridge on the host via Unix socket.
# The socket is mounted into the container at /tmp/opai-claude-bridge.sock.
#
# Usage:
#   opai-claude "explain this code"
#   echo "what does this do?" | opai-claude
#   opai-claude -f myfile.ts "review this file"

set -euo pipefail

BRIDGE_SOCKET="${OPAI_CLAUDE_BRIDGE_SOCKET:-/tmp/opai-claude-bridge.sock}"
CWD="$(pwd)"

# Parse arguments
FILE_CONTEXT=""
PROMPT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -f|--file)
      if [[ -f "$2" ]]; then
        FILE_CONTEXT="$(cat "$2")"
      else
        echo "Error: File not found: $2" >&2
        exit 1
      fi
      shift 2
      ;;
    -h|--help)
      echo "Usage: opai-claude [options] <prompt>"
      echo ""
      echo "Options:"
      echo "  -f, --file <path>   Include file contents as context"
      echo "  -h, --help          Show this help"
      echo ""
      echo "Examples:"
      echo "  opai-claude \"explain this code\""
      echo "  opai-claude -f src/index.ts \"review this file\""
      echo "  echo \"what does this do?\" | opai-claude"
      exit 0
      ;;
    *)
      PROMPT="$*"
      break
      ;;
  esac
done

# Read from stdin if no prompt given
if [[ -z "$PROMPT" ]]; then
  if [[ -t 0 ]]; then
    echo "Usage: opai-claude <prompt>" >&2
    echo "  or: echo 'prompt' | opai-claude" >&2
    exit 1
  fi
  PROMPT="$(cat)"
fi

# Prepend file context if provided
if [[ -n "$FILE_CONTEXT" ]]; then
  PROMPT="File contents:
\`\`\`
${FILE_CONTEXT}
\`\`\`

${PROMPT}"
fi

# Check socket exists
if [[ ! -S "$BRIDGE_SOCKET" ]]; then
  echo "Error: Claude bridge socket not found at $BRIDGE_SOCKET" >&2
  echo "The Claude bridge may not be running on the host." >&2
  exit 1
fi

# Escape JSON strings
json_escape() {
  printf '%s' "$1" | python3 -c 'import json,sys; print(json.dumps(sys.stdin.read()), end="")'
}

ESCAPED_PROMPT=$(json_escape "$PROMPT")
ESCAPED_CWD=$(json_escape "$CWD")

# Use Node.js to connect via Unix socket WebSocket (ws lives in Theia's node_modules)
NODE_PATH=/home/theia/node_modules node -e "
const http = require('http');
const WebSocket = require('ws');

// Connect via Unix socket
const ws = new WebSocket('ws+unix://${BRIDGE_SOCKET}:/');
let done = false;
let gotTokens = false;

ws.on('open', () => {
  ws.send(JSON.stringify({ type: 'prompt', prompt: ${ESCAPED_PROMPT}, cwd: ${ESCAPED_CWD} }));
});

ws.on('message', (raw) => {
  try {
    const msg = JSON.parse(raw.toString());
    if (msg.type === 'token') {
      gotTokens = true;
      process.stdout.write(msg.content || '');
    } else if (msg.type === 'result') {
      done = true;
      if (!gotTokens && msg.content) process.stdout.write(msg.content);
      process.stdout.write('\n');
      ws.close();
    } else if (msg.type === 'error') {
      process.stderr.write('Error: ' + (msg.message || 'Unknown error') + '\n');
      done = true;
      ws.close();
      process.exitCode = 1;
    }
  } catch (e) {
    process.stderr.write('Parse error: ' + e.message + '\n');
  }
});

ws.on('error', (err) => {
  process.stderr.write('Connection error: ' + err.message + '\n');
  process.stderr.write('Is the Claude bridge running on the host?\n');
  process.exitCode = 1;
});

ws.on('close', () => {
  if (!done) process.stdout.write('\n');
});

process.on('SIGINT', () => {
  ws.close();
  process.exit(130);
});
"
